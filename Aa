from office365.runtime.auth.authentication_context import AuthenticationContext
from office365.sharepoint.client_context import ClientContext
from office365.sharepoint.files.file import File
from io import BytesIO
import pandas as pd

# SharePoint and credentials
site_url = "https://yourcompany.sharepoint.com/sites/yoursite"
username = "your.email@yourcompany.com"
password = "your_password"

# File URLs (relative to the site)
source_file_url = "/sites/yoursite/Shared Documents/Folder1/source.xlsx"
target_file_url = "/sites/yoursite/Shared Documents/Folder2/target.xlsx"

# Authenticate
ctx_auth = AuthenticationContext(site_url)
if ctx_auth.acquire_token_for_user(username, password):
    ctx = ClientContext(site_url, ctx_auth)

    # Read source Excel file
    source_response = File.open_binary(ctx, source_file_url)
    source_bytes = BytesIO(source_response.content)
    df = pd.read_excel(source_bytes)

    print("Read data from source:")
    print(df.head())

    # Convert DataFrame to Excel in-memory
    output = BytesIO()
    df.to_excel(output, index=False)
    output.seek(0)

    # Upload to target location
    target_folder_url = "/sites/yoursite/Shared Documents/Folder2"
    target_folder = ctx.web.get_folder_by_server_relative_url(target_folder_url)
    target_folder.upload_file("target.xlsx", output.read()).execute_query()

    print("Data pasted successfully into target Excel file.")
else:
    print("Authentication failed.")
