import re
from collections import defaultdict

def clean_line(line):
    # Remove inline and block comments
    line = re.sub(r'/\*.*?\*/', '', line)
    line = re.sub(r'\*.*?;', '', line)
    return line.strip()

def extract_assignments(sas_code):
    assignments = defaultdict(set)
    reverse_assignments = defaultdict(set)
    assignment_pattern = re.compile(r'\b([a-zA-Z_]\w*)\b\s*=\s*([^;]+);')

    for line in sas_code.splitlines():
        line = clean_line(line)
        for lhs, rhs in assignment_pattern.findall(line):
            # Match only variable names on RHS
            rhs_vars = re.findall(r'\b[a-zA-Z_]\w*\b', rhs)
            for var in rhs_vars:
                if var != lhs:
                    assignments[lhs].add(var)
                    reverse_assignments[var].add(lhs)
    return assignments, reverse_assignments

def expand_dependencies(start_vars, graph):
    result = set(start_vars)
    while True:
        new_deps = set()
        for var in result:
            new_deps.update(graph.get(var, set()))
        if new_deps.issubset(result):
            break
        result.update(new_deps)
    return result

def find_if_conditions(sas_code, param):
    if_conditions = []
    pattern = re.compile(r'\bif\b\s+([^;]*?\b' + re.escape(param) + r'\b[^;]*?);', re.IGNORECASE)
    for line in sas_code.splitlines():
        line = clean_line(line)
        match = pattern.search(line)
        if match:
            if_conditions.append(line)
    return if_conditions

def extract_then_actions(if_lines):
    actions = set()
    for line in if_lines:
        if 'then' in line.lower():
            action_expr = line.lower().split('then')[-1]
            vars_in_action = re.findall(r'\b[a-zA-Z_]\w*\b', action_expr)
            actions.update(vars_in_action)
    return actions

def analyze_dependencies(sas_code, target):
    assignments, reverse_assignments = extract_assignments(sas_code)

    upstream = expand_dependencies([target], assignments)
    downstream = expand_dependencies([target], reverse_assignments)

    direct_if_conditions = find_if_conditions(sas_code, target)

    affected_outputs = set()
    downstream_if_conditions = []
    for var in downstream:
        conds = find_if_conditions(sas_code, var)
        downstream_if_conditions.extend(conds)
        affected_outputs.update(extract_then_actions(conds))

    print(f"\n[Analysis for parameter: {target}]\n")
    print(f"Upstream variables (affecting {target}): {sorted(upstream)}")
    print(f"Downstream variables (affected by {target}): {sorted(downstream)}")

    if direct_if_conditions:
        print(f"\nDirect IF conditions involving {target}:")
        for cond in direct_if_conditions:
            print(f"  - {cond}")

    if downstream_if_conditions:
        print(f"\nIF conditions triggered by downstream variables:")
        for cond in downstream_if_conditions:
            print(f"  - {cond}")

    if affected_outputs:
        print(f"\nOutputs/actions affected downstream: {sorted(affected_outputs)}")
    else:
        print("\nNo output or action triggered by downstream variables.")

# Example SAS code
sas_code = """
data temp;
    x = a + b;
    y = x * 2;
    z = y + c;
    p = z + 5;
    q = p * d;
    if z > 10 and d = 5 then output;
    if p > 100 then final_output;
run;
"""

# Analyze for a variable (e.g., z)
analyze_dependencies(sas_code, target="z")
