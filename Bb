import re
from collections import defaultdict

def extract_assignments(sas_code):
    assignment_pattern = re.compile(r'(\w+)\s*=\s*([^;]+);')
    assignments = defaultdict(set)

    for line in sas_code.splitlines():
        # Clean comments
        line = re.sub(r'/\*.*?\*/', '', line)
        line = re.sub(r'\*.*?;', '', line)

        for lhs, rhs in assignment_pattern.findall(line):
            rhs_vars = re.findall(r'\b\w+\b', rhs)
            for var in rhs_vars:
                if var != lhs:
                    assignments[lhs].add(var)
    return assignments

def trace_upstream_recursive(var, assignments, visited=None):
    if visited is None:
        visited = set()

    for dep in assignments.get(var, []):
        if dep not in visited:
            visited.add(dep)
            trace_upstream_recursive(dep, assignments, visited)
    return visited

def find_if_conditions(sas_code, param):
    if_conditions = []
    if_pattern = re.compile(r'\bif\b\s+([^;]*\b' + re.escape(param) + r'\b[^;]*);', re.IGNORECASE)
    for line in sas_code.splitlines():
        match = if_pattern.search(line)
        if match:
            if_conditions.append(line.strip())
    return if_conditions

def find_actions_from_conditions(conditions):
    actions = set()
    for cond in conditions:
        if 'then' in cond:
            action_part = cond.split('then')[-1]
            actions.update(re.findall(r'\b\w+\b', action_part))
    return actions

# Test SAS Code
sas_code = """
data temp;
    x = a + b;
    y = x * 2;
    z = y + c;
    if z > 10 and d = 5 then output;
run;
"""

target_param = "z"

assignments = extract_assignments(sas_code)
upstream_vars = trace_upstream_recursive(target_param, assignments)
if_conditions = find_if_conditions(sas_code, target_param)
downstream_effects = find_actions_from_conditions(if_conditions)

print(f"\n[ANALYSIS FOR PARAMETER: {target_param}]")
print(f"Upstream variables (affecting {target_param}): {upstream_vars}")
if if_conditions:
    print("Conditions involving parameter:")
    for cond in if_conditions:
        print(f"  - {cond}")
    print(f"Downstream effect (because of {target_param} in condition): {downstream_effects}")
else:
    print(f"No conditions involving parameter.")
