import re
from collections import defaultdict, deque

def extract_assignments(sas_code):
    assignment_pattern = re.compile(r'(\w+)\s*=\s*([^;]+);')
    assignments = defaultdict(set)

    for line in sas_code.splitlines():
        line = re.sub(r'/\*.*?\*/', '', line)  # remove block comments
        line = re.sub(r'\*.*?;', '', line)     # remove line comments

        for lhs, rhs in assignment_pattern.findall(line):
            vars_in_rhs = re.findall(r'\b\w+\b', rhs)
            for var in vars_in_rhs:
                if var != lhs:
                    assignments[lhs].add(var)
    return assignments

def trace_full_upstream(param, assignments):
    visited = set()
    queue = deque([param])
    while queue:
        var = queue.popleft()
        for dep in assignments.get(var, []):
            if dep not in visited:
                visited.add(dep)
                queue.append(dep)
                # Also explore further up from this dependency
                queue.extend(assignments.get(dep, []))
    return visited

def find_if_conditions(sas_code, param):
    if_conditions = []
    if_pattern = re.compile(r'\bif\b\s+([^;]*\b' + re.escape(param) + r'\b[^;]*);', re.IGNORECASE)
    for line in sas_code.splitlines():
        match = if_pattern.search(line)
        if match:
            if_conditions.append(line.strip())
    return if_conditions

def find_actions_from_conditions(conditions):
    actions = set()
    for cond in conditions:
        if 'then' in cond:
            action_part = cond.split('then')[-1]
            actions.update(re.findall(r'\b\w+\b', action_part))
    return actions

# Example SAS code
sas_code = """
data temp;
    x = a + b;
    y = x * 2;
    z = y + c;
    if z > 10 and d = 5 then output;
run;
"""

target_param = "z"

# Step 1: Get all assignments
assignments = extract_assignments(sas_code)

# Step 2: Trace full upstream dependencies
upstream_vars = trace_full_upstream(target_param, assignments)

# Step 3: Find `if` conditions where target param is used
if_conditions = find_if_conditions(sas_code, target_param)

# Step 4: Get actions that depend on that condition
affected_by_param = find_actions_from_conditions(if_conditions)

print(f"\n[ANALYSIS FOR PARAMETER: {target_param}]")
print(f"Upstream variables (affecting {target_param}): {upstream_vars}")
if if_conditions:
    print(f"Conditions involving {target_param}:")
    for cond in if_conditions:
        print(f"  - {cond}")
    print(f"Downstream effect (due to {target_param} in condition): {affected_by_param}")
else:
    print(f"No conditions involving {target_param}.")
