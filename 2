// ══════════════════════════════════
// UI HELPERS
// ══════════════════════════════════
function hideLoadScreen() {
  const ls = document.getElementById('loadScreen');
  ls.classList.add('hidden');
  setTimeout(() => ls.style.display = 'none', 400);
}
function showLoadScreen() {
  const ls = document.getElementById('loadScreen');
  ls.style.display = 'flex';
  setTimeout(() => ls.classList.remove('hidden'), 10);
}
function showError(msg) {
  const el = document.getElementById('loadError');
  el.textContent = msg; el.style.display = 'block';
}

// File input
document.getElementById('fileInput').addEventListener('change', e => {
  if (e.target.files[0]) readExcel(e.target.files[0]);
});

// Drag and drop
const dz = document.getElementById('dropZone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag'); });
dz.addEventListener('dragleave', () => dz.classList.remove('drag'));
dz.addEventListener('drop', e => {
  e.preventDefault(); dz.classList.remove('drag');
  if (e.dataTransfer.files[0]) readExcel(e.dataTransfer.files[0]);
});

// Scroll reveal
function initReveal() {
  const els = document.querySelectorAll('.reveal');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08 });
  els.forEach(el => { el.classList.remove('visible'); obs.observe(el); });
}
