import xlwings as xw
import pyautogui
import time
import os

# Function to copy the chart from Excel (as an object)
def copy_chart_in_excel(excel_file, sheet_name, chart_index):
    app = xw.App(visible=True)
    wb = app.books.open(excel_file)
    ws = wb.sheets[sheet_name]
    
    # Select the chart object in Excel
    chart = ws.charts[chart_index]
    
    # Copy the chart as a picture (vectorized)
    chart.api.Copy()  # Directly copies as an object (retain quality)
    
    # Wait for clipboard action to complete
    time.sleep(1)
    wb.close()
    app.quit()

# Function to paste the chart into PowerPoint
def paste_chart_into_ppt(ppt_file):
    # Open PowerPoint using pyautogui (you can switch with Alt+Tab if necessary)
    pyautogui.hotkey('alt', 'tab')  # Switch to PowerPoint
    
    # Give some time for PowerPoint to come to the foreground
    time.sleep(1)
    
    # Simulate Ctrl + V to paste the chart
    pyautogui.hotkey('ctrl', 'v')
    time.sleep(1)  # Allow time for the chart to paste

    # Optionally, save and close PowerPoint after paste
    pyautogui.hotkey('ctrl', 's')  # Save
    time.sleep(1)
    pyautogui.hotkey('ctrl', 'w')  # Close PowerPoint

# Define paths and parameters
excel_file = "path_to_your_excel_file.xlsx"
sheet_name = "Sheet1"  # Adjust based on your sheet
chart_index = 0  # Index of the chart in Excel
ppt_file = "path_to_your_presentation.pptx"  # PowerPoint file path

# Copy the chart from Excel
copy_chart_in_excel(excel_file, sheet_name, chart_index)

# Paste the chart into PowerPoint
paste_chart_into_ppt(ppt_file)

print("Chart successfully copied and pasted into PowerPoint!")
